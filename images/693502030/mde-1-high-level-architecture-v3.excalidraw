    {
      "type": "text",
      "id": "t21",
      "x": 128,
      "y": 656,
      "text": "BROADCAST SERVICE\n\nKafka pull for live ticks\nRedis snapshot on connect\n\u2192 Protobuf \u2192 WebSocket\n\u2192 End Users",
      "fontSize": 11,
      "strokeColor": "#1971c2"
    },
    {
      "type": "rectangle",
      "id": "r22",
      "x": 437,
      "y": 642,
      "width": 300,
      "height": 98,
      "backgroundColor": "#d3f9d8",
      "strokeColor": "#2f9e44",
      "strokeWidth": 2,
