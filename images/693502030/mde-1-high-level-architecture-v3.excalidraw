  "source": "claude-code",
  "elements": [
    {
      "type": "text",
      "id": "t1",
      "x": 380,
      "y": 20,
      "text": "Market Data Engine \u2014 High Level Architecture (v3)",
      "fontSize": 28,
      "strokeColor": "#1e1e1e"
    },
    {
      "type": "text",
      "id": "t2",
      "x": 520,
      "y": 60,
      "text": "Merged feed architecture | Kafka-based delivery | 2 Redis clusters",
      "fontSize": 13,
      "strokeColor": "#868e96"
    },
    {
      "type": "rectangle",
      "id": "r3",
      "x": 410,
      "y": 110,
      "width": 680,
      "height": 103,
      "backgroundColor": "#fff3bf",
      "strokeColor": "#e67700",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t4",
      "x": 426,
      "y": 126,
      "text": "EXCHANGE FEEDS  (Merged \u2014 Best of Both)\n\nNSE Direct + Omnenest  \u2192  Single pipeline\nDedup by (instrument, timestamp):  whichever arrives first wins",
      "fontSize": 14,
      "strokeColor": "#e67700"
    },
    {
      "type": "text",
      "id": "t5",
      "x": 500,
      "y": 218,
      "text": "\u2193  UDP Multicast (6 streams \u00d7 8192 byte buffer)  +  Omnenest RS protocol",
      "fontSize": 11,
      "strokeColor": "#868e96"
    },
    {
      "type": "text",
      "id": "t6",
      "x": 600,
      "y": 238,
      "text": "(External circuit breaker \u2014 not our service)",
      "fontSize": 10,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "rectangle",
      "id": "r7",
      "x": 420,
      "y": 268,
      "width": 660,
      "height": 98,
      "backgroundColor": "#d0bfff",
      "strokeColor": "#7048e8",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t8",
      "x": 436,
      "y": 284,
      "text": "FEED HANDLER  (~4K TPS in  \u2192  ~2K after dedup)\n\nReceive \u2192 Decode \u2192 Cross-Source Dedup \u2192 Denormalize \u2192 Duplicate Detector\nSequence Gap Detection  |  Processor routing by packet code",
      "fontSize": 13,
      "strokeColor": "#7048e8"
    },
