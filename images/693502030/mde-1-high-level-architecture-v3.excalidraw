      "opacity": 100
    },
    {
      "type": "text",
      "id": "t48",
      "x": 646,
      "y": 1114,
      "text": "Kafka\n\nDurable tick stream\n6 segment topics\n3-7 day retention\n\nWritten by Producer\nRead by Broadcast + Writers",
      "fontSize": 10,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "rectangle",
      "id": "r49",
      "x": 890,
      "y": 1102,
