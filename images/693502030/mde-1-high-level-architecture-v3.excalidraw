      "opacity": 100
    },
    {
      "type": "text",
      "id": "t23",
      "x": 453,
      "y": 656,
      "text": "CHARTS DATA WRITER\n\nKafka \u2192 TimescaleDB ticks\n+ TimescaleDB candles_1m\n(5m/15m/1h/1d auto-generated)",
      "fontSize": 11,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "rectangle",
      "id": "r24",
