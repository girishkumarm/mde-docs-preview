    {
      "type": "text",
      "id": "t25",
      "x": 778,
      "y": 656,
      "text": "FNO DATA WRITER\n\nKafka \u2192 Black-Scholes Greeks\n\u2192 Option chain in Redis 2\n\u2192 PCR, Max Pain, ATM Straddle",
      "fontSize": 11,
      "strokeColor": "#e8590c"
