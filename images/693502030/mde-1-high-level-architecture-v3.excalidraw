    {
      "type": "text",
      "id": "t44",
      "x": 126,
      "y": 1114,
      "text": "Redis Cluster 1  (FEED)\n\nLive tick snapshots\nFEED_PP, OHLC, PC\nCKT, 52-week H/L, TRD_DAY\n\nWritten by Publisher\nRead by Periscope, Broadcast",
      "fontSize": 10,
      "strokeColor": "#1971c2"
    },
    {
      "type": "rectangle",
      "id": "r45",
      "x": 370,
      "y": 1102,
      "width": 240,
      "height": 126,
