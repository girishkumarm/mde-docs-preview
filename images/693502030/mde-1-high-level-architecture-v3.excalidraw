    {
      "type": "text",
      "id": "t46",
      "x": 386,
      "y": 1114,
      "text": "Redis Cluster 2  (API)\n\nCurrent-day candles\nFNO option chain + insights\nMarket movers sorted sets\n\nWritten by 3 Writers\nRead by 3 APIs",
      "fontSize": 10,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "rectangle",
      "id": "r47",
      "x": 630,
      "y": 1102,
      "width": 240,
      "height": 126,
      "backgroundColor": "#d3f9d8",
