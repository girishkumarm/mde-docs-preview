    {
      "type": "text",
      "id": "t12",
      "x": 186,
      "y": 460,
      "text": "PUBLISHER\n\nWrites to Redis Cluster 1 (Feed)\nHash snapshots + Lua atomic updates\n(52wk H/L, OHLC compare-and-set)",
      "fontSize": 13,
      "strokeColor": "#1971c2"
    },
    {
      "type": "rectangle",
      "id": "r13",
      "x": 770,
      "y": 446,
      "width": 360,
      "height": 111,
      "backgroundColor": "#d3f9d8",
      "strokeColor": "#2f9e44",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t14",
      "x": 786,
      "y": 460,
      "text": "PRODUCER\n\nWrites to Kafka  (acks=all, idempotent)\n6 segment topics \u2014 durable stream\nConsumed by Broadcast + 3 Writers",
      "fontSize": 13,
      "strokeColor": "#2f9e44"
    },
