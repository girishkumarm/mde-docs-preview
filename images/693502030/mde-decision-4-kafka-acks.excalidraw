  "elements": [
    {
      "type": "text",
      "id": "t1",
      "x": 200,
      "y": 20,
      "text": "Decision 4: Kafka acks=all (Zero Tick Loss)",
      "fontSize": 24,
      "strokeColor": "#1e1e1e"
    },
    {
      "type": "text",
      "id": "t2",
      "x": 200,
      "y": 55,
      "text": "Problem: acks=1 means only leader confirms. Leader crash before replication = tick lost forever.",
      "fontSize": 12,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "text",
      "id": "t3",
      "x": 50,
      "y": 100,
      "text": "BEFORE \u2014 acks=1 (Unsafe)",
      "fontSize": 18,
      "strokeColor": "#c92a2a"
    },
