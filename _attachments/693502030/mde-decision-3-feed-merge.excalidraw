    {
      "type": "text",
      "id": "t17",
      "x": 66,
      "y": 350,
      "text": "85% users\n\u2192 FAST prices\n(NSE speed)",
      "fontSize": 11,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "rectangle",
      "id": "r18",
      "x": 320,
      "y": 338,
      "width": 230,
      "height": 66,
      "backgroundColor": "#ffe3e3",
      "strokeColor": "#c92a2a",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t19",
      "x": 336,
      "y": 350,
      "text": "15% users\n\u2192 SLOWER prices\n(Omnenest speed)",
      "fontSize": 11,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "rectangle",
      "id": "r20",
      "x": 50,
      "y": 429,
      "width": 500,
      "height": 98,
      "backgroundColor": "#ffe3e3",
      "strokeColor": "#c92a2a",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t21",
      "x": 66,
      "y": 443,
      "text": "PROBLEMS:\n\u2022 15% users see prices 3-8 ms later\n\u2022 NSE UDP packet drop \u2192 data LOST forever\n  (no automatic recovery from Omnenest)\n\u2022 Failover requires rerouting users mid-session",
      "fontSize": 11,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "text",
      "id": "t22",
      "x": 780,
      "y": 100,
      "text": "AFTER \u2014 Merge Both (Best-of-Both)",
      "fontSize": 18,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "rectangle",
      "id": "r23",
      "x": 780,
      "y": 140,
      "width": 230,
      "height": 52,
      "backgroundColor": "#fff3bf",
      "strokeColor": "#e67700",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t24",
      "x": 796,
      "y": 152,
      "text": "NSE Direct\n~2K TPS",
      "fontSize": 11,
      "strokeColor": "#e67700"
    },
    {
      "type": "rectangle",
      "id": "r25",
      "x": 1050,
      "y": 140,
      "width": 230,
      "height": 52,
      "backgroundColor": "#ffe8cc",
      "strokeColor": "#e8590c",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
