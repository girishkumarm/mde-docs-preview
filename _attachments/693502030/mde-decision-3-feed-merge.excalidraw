  "elements": [
    {
      "type": "text",
      "id": "t1",
      "x": 150,
      "y": 20,
      "text": "Decision 3: Merge NSE + Omnenest into Single Pipeline",
      "fontSize": 24,
      "strokeColor": "#1e1e1e"
    },
    {
      "type": "text",
      "id": "t2",
      "x": 150,
      "y": 55,
      "text": "Problem: 85/15 user split meant 15% saw slower prices. UDP gaps had no automatic recovery.",
      "fontSize": 12,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "text",
      "id": "t3",
      "x": 50,
      "y": 100,
      "text": "BEFORE \u2014 Split by User Session",
      "fontSize": 18,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "rectangle",
      "id": "r4",
      "x": 50,
