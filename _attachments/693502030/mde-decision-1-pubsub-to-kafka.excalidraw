    {
      "type": "text",
      "id": "t12",
      "x": 186,
      "y": 236,
      "text": "Publisher  writes to Redis\nHash + PubSub PUSH\n(same connection)",
      "fontSize": 11,
      "strokeColor": "#1971c2"
    },
    {
      "type": "rectangle",
      "id": "r13",
      "x": 800,
      "y": 224,
      "width": 220,
      "height": 66,
      "backgroundColor": "#d0ebff",
      "strokeColor": "#1971c2",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t14",
      "x": 816,
      "y": 236,
      "text": "Publisher\n\u2192 Redis Hash\n(snapshot only)",
      "fontSize": 11,
      "strokeColor": "#1971c2"
    },
    {
      "type": "rectangle",
      "id": "r15",
      "x": 1070,
      "y": 224,
      "width": 220,
      "height": 66,
      "backgroundColor": "#d3f9d8",
      "strokeColor": "#2f9e44",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t16",
      "x": 1086,
      "y": 236,
      "text": "Producer\n\u2192 Kafka\n(acks=all)",
      "fontSize": 11,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "arrow",
      "id": "a17",
      "x": 360,
      "y": 290,
      "width": 0,
      "height": 30,
      "strokeColor": "#1971c2",
      "strokeWidth": 1,
      "points": [
        [
          0,
          0
        ],
        [
          0,
          30
        ]
      ]
    },
    {
      "type": "arrow",
      "id": "a18",
      "x": 1180,
      "y": 290,
      "width": 0,
      "height": 30,
      "strokeColor": "#2f9e44",
      "strokeWidth": 1,
      "points": [
        [
          0,
          0
        ],
        [
          0,
          30
        ]
      ]
    },
    {
      "type": "rectangle",
      "id": "r19",
      "x": 130,
      "y": 320,
      "width": 460,
      "height": 98,
      "backgroundColor": "#ffe3e3",
      "strokeColor": "#c92a2a",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t20",
      "x": 146,
      "y": 334,
      "text": "Redis (SINGLE THREAD)\n\nOn every publish, must COPY message\nto each subscriber pod's buffer\n20K msgs/sec \u00d7 20 pods = 400K ops/sec",
      "fontSize": 11,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "rectangle",
      "id": "r21",
      "x": 970,
      "y": 320,
      "width": 460,
      "height": 98,
      "backgroundColor": "#d3f9d8",
      "strokeColor": "#2f9e44",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t22",
      "x": 986,
      "y": 334,
      "text": "Kafka (multi-partition)\n\nWrites ONCE to disk per message\nEach pod PULLS at its own pace\n10 pods or 100 pods = same Kafka load",
      "fontSize": 11,
      "strokeColor": "#2f9e44"
    },
