    {
      "type": "text",
      "id": "t53",
      "x": 80,
      "y": 533,
      "text": "At 100K concurrent connections:\n\u2192 Redis single thread hits 100% CPU\n\u2192 Publish latency climbs from <1ms to 50-100ms\n\u2192 Users see frozen / delayed prices",
      "fontSize": 11,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "text",
      "id": "t54",
      "x": 780,
      "y": 533,
      "text": "At 100K or 1M concurrent connections:\n\u2192 Kafka just writes ONCE per tick\n\u2192 Each pod's consumer pulls independently\n\u2192 Horizontal scale is unlimited",
      "fontSize": 11,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "rectangle",
      "id": "r55",
      "x": 50,
      "y": 623,
      "width": 1320,
      "height": 78,
      "backgroundColor": "#fff9db",
      "strokeColor": "#f08c00",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t56",
      "x": 66,
      "y": 639,
      "text": "TRADEOFF:  PubSub push was <1 ms delivery.  Kafka pull is 2-5 ms delivery.\nHuman reaction time = 200 ms, so the 1-4 ms difference is invisible to every user.\nWhat IS visible: frozen prices when PubSub saturates at scale.  Kafka never has this problem.",
      "fontSize": 12,
      "strokeColor": "#f08c00"
    }
  ],
