{
  "type": "excalidraw",
  "version": 2,
  "source": "claude-code",
  "elements": [
    {
      "type": "text",
      "id": "t1",
      "x": 150,
      "y": 20,
      "text": "Decision 1: Replace Redis PubSub with Kafka Pull",
      "fontSize": 24,
      "strokeColor": "#1e1e1e"
    },
    {
      "type": "text",
      "id": "t2",
      "x": 150,
      "y": 55,
      "text": "Problem: Redis PubSub is single-threaded. Fan-out to 20+ pods at high TPS saturates the CPU.",
      "fontSize": 12,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "text",
      "id": "t3",
      "x": 150,
      "y": 100,
      "text": "BEFORE \u2014 Redis PubSub (Push)",
      "fontSize": 18,
      "strokeColor": "#c92a2a"
    },
    {
      "type": "text",
      "id": "t4",
      "x": 900,
      "y": 100,
      "text": "AFTER \u2014 Kafka (Pull)",
      "fontSize": 18,
      "strokeColor": "#2f9e44"
    },
    {
      "type": "rectangle",
      "id": "r5",
      "x": 230,
      "y": 140,
      "width": 260,
      "height": 54,
      "backgroundColor": "#d0bfff",
      "strokeColor": "#7048e8",
      "strokeWidth": 2,
      "fillStyle": "hachure",
      "roughness": 0,
      "opacity": 100
    },
    {
      "type": "text",
      "id": "t6",
      "x": 246,
      "y": 152,
      "text": "Feed Handler\nprocesses ticks",
      "fontSize": 12,
      "strokeColor": "#7048e8"
    },
    {
